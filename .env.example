# Google Drive Service Account
# Paste the full JSON content of your service account key here (single line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Blotato API Key (from https://my.blotato.com/settings)
BLOTATO_API_KEY=your_blotato_api_key_here

# ── Sir Supreme ──────────────────────────────────────────────
# Drive folder ID is hardcoded in config.py (Sir Supreme Final Edits)
SIR_SUPREME_YOUTUBE_ACCOUNT_ID=your_blotato_youtube_account_id
SIR_SUPREME_INSTAGRAM_ACCOUNT_ID=your_blotato_instagram_account_id

# ── Sir Supreme Kannada ──────────────────────────────────────
# Drive folder ID is hardcoded in config.py (Sir Supreme Kannada Final Edits)
SIR_SUPREME_KANNADA_YOUTUBE_ACCOUNT_ID=your_blotato_youtube_account_id
SIR_SUPREME_KANNADA_INSTAGRAM_ACCOUNT_ID=your_blotato_instagram_account_id

# ── Supreme Tamilan ──────────────────────────────────────────
# Drive folder ID is hardcoded in config.py (Supreme Tamilan Final Edits)
SUPREME_TAMILAN_YOUTUBE_ACCOUNT_ID=your_blotato_youtube_account_id
